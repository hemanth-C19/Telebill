{
  "info": {
    "name": "Coding APIs",
    "description": "Medical Coding management endpoints for Telebill (ICD, CPT, HCPCS codes)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Diagnosis Codes (ICD)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/coding/diagnosis-codes",
          "host": ["{{base_url}}"],
          "path": ["api", "coding", "diagnosis-codes"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
