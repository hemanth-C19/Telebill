    {
      "name": "Code Encounter Diagnoses",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"encounterId\": \"{{encounterId}}\",\n  \"diagnoses\": [\n    {\n      \"diagnosisCodeId\": \"E11\",\n      \"description\": \"Type 2 Diabetes Mellitus\",\n      \"primaryDiagnosis\": true,\n      \"severity\": \"moderate\"\n    },\n    {\n      \"diagnosisCodeId\": \"I10\",\n      \"description\": \"Essential Hypertension\",\n      \"primaryDiagnosis\": false,\n      \"severity\": \"mild\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/coding/code-diagnoses",
          "host": ["{{base_url}}"],
          "path": ["api", "coding", "code-diagnoses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set('codedDiagnosisId', jsonData.id);"
            ]
          }
        }
      ]
    },
