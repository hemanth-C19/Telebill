            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"closed\",\n  \"notes\": \"Encounter completed successfully\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/encounters/{{encounterId}}/close",
          "host": ["{{base_url}}"],
          "path": ["api", "encounters", "{{encounterId}}", "close"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Encounter",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/encounters/{{encounterId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "encounters", "{{encounterId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 204 or 200', function () {",
              "  pm.response.to.have.status([200, 204]);",
              "});"
            ]
          }
        }
      ]
    }
  ],
