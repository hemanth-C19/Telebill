    {
      "name": "Get Encounters by Date Range",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/encounters/date-range?startDate=2024-01-01&endDate=2024-12-31",
          "host": ["{{base_url}}"],
          "path": ["api", "encounters", "date-range"],
          "query": [
            {
              "key": "startDate",
              "value": "2024-01-01"
            },
            {
              "key": "endDate",
              "value": "2024-12-31"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Vitals to Encounter",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"encounterId\": \"{{encounterId}}\",\n  \"temperature\": 98.6,\n  \"bloodPressure\": \"120/80\",\n  \"heartRate\": 72,\n  \"respiratoryRate\": 16,\n  \"weight\": 75,\n  \"height\": 175,\n  \"bmi\": 24.5,\n  \"oxygenSaturation\": 98\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/encounters/{{encounterId}}/vitals",
          "host": ["{{base_url}}"],
          "path": ["api", "encounters", "{{encounterId}}", "vitals"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Medications to Encounter",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"encounterId\": \"{{encounterId}}\",\n  \"medications\": [\n    {\n      \"medicationName\": \"Aspirin\",\n      \"dosage\": \"100mg\",\n      \"frequency\": \"Once daily\",\n      \"duration\": \"30 days\",\n      \"instructions\": \"Take with food\"\n    },\n    {\n      \"medicationName\": \"Lisinopril\",\n      \"dosage\": \"10mg\",\n      \"frequency\": \"Once daily\",\n      \"duration\": \"Ongoing\",\n      \"instructions\": \"Take in the morning\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/encounters/{{encounterId}}/medications",
          "host": ["{{base_url}}"],
          "path": ["api", "encounters", "{{encounterId}}", "medications"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
