          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"encounterId\": {{encounterId}},\n  \"code\": \"I10\",\n  \"description\": \"Essential hypertension\",\n  \"isPrimary\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/coding/diagnoses?userId={{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "diagnoses"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
