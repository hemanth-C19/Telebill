            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"I11\",\n  \"description\": \"Hypertension with heart disease\",\n  \"isPrimary\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/coding/diagnoses/{{dxId}}?userId={{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "diagnoses", "{{dxId}}"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Remove Diagnosis",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/coding/diagnoses/{{dxId}}?userId={{userId}}",
