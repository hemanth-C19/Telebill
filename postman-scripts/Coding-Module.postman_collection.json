              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "worklist", "{{encounterId}}", "charge-lines", "{{chargeId}}", "modifiers"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            }
