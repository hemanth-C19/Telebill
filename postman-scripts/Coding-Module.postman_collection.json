{
  "info": {
    "name": "Telebill Coding Module",
    "description": "API collection for Telebill Coding module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Provider Portal",
      "item": [
        {
          "name": "Get Provider Encounters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/coding/provider/encounters?providerId={{providerId}}&status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "provider", "encounters"],
              "query": [
                {
                  "key": "providerId",
                  "value": "{{providerId}}"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "Get Provider Encounter Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/coding/provider/encounters/{{encounterId}}?providerId={{providerId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "provider", "encounters", "{{encounterId}}"],
              "query": [
                {
                  "key": "providerId",
                  "value": "{{providerId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Set Documentation URI",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentationUri\": \"https://example.com/docs/encounter-123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/coding/provider/encounters/{{encounterId}}/documentation?providerId={{providerId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "provider", "encounters", "{{encounterId}}", "documentation"],
              "query": [
                {
                  "key": "providerId",
                  "value": "{{providerId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Mark Ready for Coding",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/coding/provider/encounters/{{encounterId}}/ready-for-coding?providerId={{providerId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "coding", "provider", "encounters", "{{encounterId}}", "ready-for-coding"],
              "query": [
                {
                  "key": "providerId",
                  "value": "{{providerId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
