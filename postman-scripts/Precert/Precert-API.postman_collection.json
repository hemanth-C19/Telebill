{
  "info": {
    "name": "Pre-Certification APIs",
    "description": "Pre-Authorization/Pre-Certification management endpoints for Telebill",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Pre-Certifications",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/precert",
          "host": ["{{base_url}}"],
          "path": ["api", "precert"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Pre-Certification by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/precert/{{precertId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "precert", "{{precertId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has id property', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Submit Pre-Certification Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"providerId\": \"{{providerId}}\",\n  \"insuranceId\": \"{{insuranceId}}\",\n  \"requestType\": \"pre-authorization\",\n  \"procedureCode\": \"27447\",\n  \"procedureName\": \"Total Knee Replacement\",\n  \"diagnosisCodes\": [\"M17.11\"],\n  \"estimatedAmount\": 50000,\n  \"proposedDate\": \"2024-02-15\",\n  \"facility\": \"City Hospital\",\n  \"justificationNotes\": \"Patient requires surgery for severe osteoarthritis\",\n  \"attachments\": []\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/precert/request",
          "host": ["{{base_url}}"],
          "path": ["api", "precert", "request"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set('precertId', jsonData.id);"
            ]
          }
        }
      ]
    },
