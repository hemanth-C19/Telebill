    {
      "name": "Approve Pre-Certification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"approvedAmount\": 50000,\n  \"approvalDate\": \"2024-01-20\",\n  \"authorizationNumber\": \"AUTH-2024-001\",\n  \"validUntilDate\": \"2024-04-20\",\n  \"conditions\": \"Prior authorization valid for single procedure only\",\n  \"reviewedBy\": \"{{reviewerId}}\",\n  \"approvalNotes\": \"Approved - Medical necessity confirmed\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/precert/{{precertId}}/approve",
          "host": ["{{base_url}}"],
          "path": ["api", "precert", "{{precertId}}", "approve"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set('authorizationNumber', jsonData.authorizationNumber);"
            ]
          }
        }
      ]
    },
