          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"paymentAmount\": 500,\n  \"paymentDate\": \"2024-01-15\",\n  \"paymentMethod\": \"credit_card\",\n  \"referenceNumber\": \"PAY-2024-001\",\n  \"description\": \"Patient payment for account\",\n  \"applyClaim\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/ar/payment/patient",
          "host": ["{{base_url}}"],
          "path": ["api", "ar", "payment", "patient"]
