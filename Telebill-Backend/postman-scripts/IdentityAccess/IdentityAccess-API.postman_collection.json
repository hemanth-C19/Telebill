{
  "info": {
    "name": "Identity & Access APIs",
    "description": "Identity and Access Control endpoints for Telebill",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get User Roles",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/identity-access/roles",
          "host": ["{{base_url}}"],
          "path": ["api", "identity-access", "roles"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Assign Role to User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"roleId\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/identity-access/assign-role",
          "host": ["{{base_url}}"],
          "path": ["api", "identity-access", "assign-role"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Permissions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/identity-access/permissions",
          "host": ["{{base_url}}"],
          "path": ["api", "identity-access", "permissions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Grant Permission",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"roleId\": \"admin\",\n  \"permissionId\": \"read:users\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/identity-access/grant-permission",
          "host": ["{{base_url}}"],
          "path": ["api", "identity-access", "grant-permission"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Verify Access",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/identity-access/verify?resource=users&action=read",
          "host": ["{{base_url}}"],
          "path": ["api", "identity-access", "verify"],
          "query": [
            {
              "key": "resource",
              "value": "users"
            },
            {
              "key": "action",
              "value": "read"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has access property', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('access');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ]
}
